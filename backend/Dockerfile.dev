# Use platform-specific base image for M1 Macs
FROM --platform=linux/amd64 node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Build the app
RUN npm run build

# Expose port 5000
EXPOSE 5000

# Start the application in development mode
CMD ["npm", "run", "dev"]
