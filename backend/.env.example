# Application Environment
NODE_ENV=development
PORT=5000

# CORS Configuration
# Use '*' for development, specify origins for production
CORS_ORIGIN=*

# Logging Configuration
LOG_LEVEL=info
LOGS_DIR=./logs

# WebSocket Configuration
WS_PATH=/ws
WS_PING_INTERVAL=30000

# Mining Configuration
# Update interval in milliseconds (how often to update mining stats)
MINING_UPDATE_INTERVAL=5000

# Maximum number of history points to keep in memory
MINING_MAX_HISTORY=60

# Miner Configuration Path
MINER_CONFIG_PATH=/opt/mining-stack/etc/miners.yaml

# Simulation Configuration (for demo/testing)
# Probability that a miner is online (0.0-1.0, default 0.9 = 90%)
SIM_ONLINE_PROBABILITY=0.9

# Probability of error when online (0.0-1.0, default 0.2 = 20%)
SIM_ERROR_PROBABILITY=0.2

# Hashrate variance as a fraction (default 0.1 = ±10%)
SIM_HASHRATE_VARIANCE=0.1

# Hardware simulation ranges
SIM_TEMP_MIN=60
SIM_TEMP_MAX=90
SIM_FAN_MIN=3000
SIM_FAN_MAX=5000
SIM_POWER_MIN=2000
SIM_POWER_MAX=3000

# Database Configuration (if using a database in the future)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mining_monitor
# DB_USER=admin
# DB_PASSWORD=your_secure_password

# API Configuration
# API_KEY=your_api_key_here
# API_SECRET=your_api_secret_here

# WebSocket Configuration
# WS_PORT=5000
# WS_PATH=/ws

# Monitoring Configuration
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001

# Security
# JWT_SECRET=your_jwt_secret_here
# SESSION_SECRET=your_session_secret_here

# Email Notifications (for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_email_password
# SMTP_FROM=Mining Monitor <noreply@miningmonitor.com>

# Alert Configuration (for future use)
# ALERT_EMAIL=admin@example.com
# ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Feature Flags
# ENABLE_AUTHENTICATION=false
# ENABLE_NOTIFICATIONS=false
# ENABLE_ANALYTICS=true
