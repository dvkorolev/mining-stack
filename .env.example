# =============================================================================
# Mining Stack Production Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment
# DO NOT commit .env to git (it contains secrets)

# -----------------------------------------------------------------------------
# Docker Registry Configuration
# -----------------------------------------------------------------------------
GITHUB_REPOSITORY=dvkorolev/mining-stack
IMAGE_TAG=latest

# Optional: GitHub Authentication (for private packages)
# GITHUB_USERNAME=your_username
# GITHUB_TOKEN=your_personal_access_token

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=5000
LOG_LEVEL=info
CORS_ORIGIN=*

# ALLOW_LEGACY_HEADER_AUTH=false  # insecure X-Telegram-Chat-ID admin fallback; keep false unless required

# JWT secrets — REQUIRED in production; generate with: openssl rand -hex 32
# JWT_ACCESS_SECRET=replace_with_a_secure_random_secret
# JWT_REFRESH_SECRET=replace_with_a_secure_random_secret

# Paths
DATA_DIR=/app/data
LOGS_DIR=/app/logs
MINER_CONFIG_PATH=/opt/mining-stack/etc/miners.yaml

# Mining Stats
MINING_UPDATE_INTERVAL=30000
MINING_MAX_HISTORY=60
USE_REAL_DATA=true

# Prometheus Integration
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_ENABLED=true

# Job Runner Service
JOB_RUNNER_URL=http://python-scheduler:8000

# -----------------------------------------------------------------------------
# Python Scheduler Configuration
# -----------------------------------------------------------------------------
METRICS_DIR=/metrics
MINERS_CONFIG=/app/etc/miners.yaml
POOLS_CONFIG=/app/etc/pools.yaml
COLLECTION_INTERVAL=2
POOL_TEST_INTERVAL=5
ENABLE_ICMP_PING=false
BACKEND_URL=http://backend:5000
PUSH_TO_BACKEND=true
# INTERNAL_METRICS_TOKEN=set_shared_secret_for_scheduler_metrics_push  # optional in dev, required in production

# Logging Configuration
LOG_FORMAT=json
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Alert Thresholds (Global Defaults)
# -----------------------------------------------------------------------------
# Temperature thresholds (Celsius)
# WARNING: Your miners are running 88-105°C! This is dangerous!
# Adjust these thresholds based on your cooling situation:
THRESHOLD_TEMP_WARNING=85   # Yellow warning
THRESHOLD_TEMP_CRITICAL=95  # Red critical (hardware damage risk)
THRESHOLD_TEMP_SHUTDOWN=105 # Emergency shutdown needed

# Hashrate thresholds (percent below expected)
THRESHOLD_HASHRATE_WARNING_PCT=20
THRESHOLD_HASHRATE_CRITICAL_PCT=50

# Power thresholds (percent deviation)
THRESHOLD_POWER_WARNING_PCT=15

# Rejection rate thresholds (percent)
THRESHOLD_REJECTION_WARNING=2.0
THRESHOLD_REJECTION_CRITICAL=5.0

# Fan speed thresholds (RPM)
THRESHOLD_FAN_WARNING=3000
THRESHOLD_FAN_CRITICAL=2000

# -----------------------------------------------------------------------------
# Grafana Configuration
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=mining123
GF_USERS_ALLOW_SIGN_UP=false
GF_SERVER_ROOT_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Telegram Bot Configuration (Optional)
# -----------------------------------------------------------------------------
# Configure via Web UI at http://localhost:3000/settings
# Or set environment variables directly:

# Bot Token from @BotFather
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Comma-separated list of authorized Telegram Chat IDs
# Get your Chat ID by sending /whoami to your bot
# TELEGRAM_CHAT_ID=123456789,987654321

# Admin Telegram Chat ID (for ownership transfer and admin features)
# This should be ONE admin user's Chat ID
# ADMIN_TELEGRAM_CHAT_ID=123456789

# -----------------------------------------------------------------------------
# Multi-User Database Configuration
# -----------------------------------------------------------------------------
# System API Key for internal service authentication (python-scheduler -> backend)
# Generate a secure random key: openssl rand -hex 32
# SYSTEM_API_KEY=your_secure_random_key_here

# Database Configuration Mode
# Set to 'true' to use database instead of YAML for miner configuration
# Set to 'false' to fallback to YAML (for migration period)
# USE_DATABASE_CONFIG=true
