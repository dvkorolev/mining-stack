{
  "id": null,
  "uid": "per-miner-details",
  "title": "Per-Miner Details (SHA-256)",
  "tags": ["mining", "per-miner", "sha256"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "type": "timeseries",
      "title": "SHA-256 Hashrate by Miner (TH/s)",
      "targets": [
        {
          "expr": "max by (ip, name) (miner_hashrate_ths{algorithm=\"sha256\"})",
          "legendFormat": "{{name}} ({{ip}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "axisLabel": "Hashrate (TH/s)",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "unit": "TH/s",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 2,
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 10},
      "type": "timeseries",
      "title": "SHA-256 Power Consumption by Miner (W)",
      "targets": [{
        "expr": "max by (ip, name) (miner_power_watts{algorithm=\"sha256\"})",
        "legendFormat": "{{name}} ({{ip}})",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "axisLabel": "Power (W)",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "unit": "watt",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 3,
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 20},
      "type": "timeseries",
      "title": "SHA-256 Rejection Rate by Miner (%) - Lifetime",
      "targets": [{
        "expr": "100 * (max by (ip, name) (miner_pool_rejected_total{algorithm=\"sha256\"}) / (max by (ip, name) (miner_pool_accepted_total{algorithm=\"sha256\"}) + max by (ip, name) (miner_pool_rejected_total{algorithm=\"sha256\"})))",
        "legendFormat": "{{name}} ({{ip}})",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "axisLabel": "Rejection Rate (%)",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 2, "color": "yellow"},
              {"value": 5, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 4,
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 30},
      "type": "timeseries",
      "title": "SHA-256 Temperature by Miner (°C)",
      "targets": [{
        "expr": "max by (ip, name) (miner_temp_max_c{algorithm=\"sha256\"})",
        "legendFormat": "{{name}} ({{ip}})",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "axisLabel": "Temperature (°C)",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "unit": "celsius",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 75, "color": "yellow"},
              {"value": 85, "color": "orange"},
              {"value": 95, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 5,
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 40},
      "type": "table",
      "title": "SHA-256 Detailed Miner Statistics",
      "targets": [
        {
          "expr": "max by (ip, name, model, algorithm) (miner_hashrate_ths{algorithm=\"sha256\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "max by (ip) (miner_power_watts{algorithm=\"sha256\"})",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "max by (ip) (miner_temp_max_c{algorithm=\"sha256\"})",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "max by (ip) (miner_efficiency_j_th{algorithm=\"sha256\"})",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "100 * (max by (ip) (miner_pool_rejected_total{algorithm=\"sha256\"}) / (max by (ip) (miner_pool_accepted_total{algorithm=\"sha256\"}) + max by (ip) (miner_pool_rejected_total{algorithm=\"sha256\"})))",
          "format": "table",
          "instant": true,
          "refId": "E"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "indexByName": {
              "name": 0,
              "ip": 1,
              "model": 2,
              "Value #A": 3,
              "Value #B": 4,
              "Value #C": 5,
              "Value #D": 6,
              "Value #E": 7
            },
            "renameByName": {
              "name": "Miner",
              "ip": "IP",
              "model": "Model",
              "Value #A": "Hashrate (TH/s)",
              "Value #B": "Power (W)",
              "Value #C": "Temp (°C)",
              "Value #D": "Efficiency (J/TH)",
              "Value #E": "Rejection (%)"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Temp (°C)"},
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 75, "color": "yellow"},
                    {"value": 85, "color": "orange"},
                    {"value": 95, "color": "red"}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Rejection (%)"},
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 2, "color": "yellow"},
                    {"value": 5, "color": "red"}
                  ]
                }
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Hashrate (TH/s)"},
            "properties": [
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Power (W)"},
            "properties": [
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Efficiency (J/TH)"},
