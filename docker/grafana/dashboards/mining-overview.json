{
  "id": null,
  "uid": "mining-farm-overview",
  "title": "Mining Farm Overview",
    "tags": ["mining", "overview"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "links": [],
    "liveNow": false,
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {},
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "type": "stat",
        "title": "Total Hashrate (SHA-256)",
        "targets": [{
          "expr": "sum(max by (ip) (miner_hashrate_ths{algorithm=\"sha256\"}))",
          "legendFormat": "SHA-256"
        }],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "unit": "TH/s",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1000, "color": "yellow"},
                {"value": 1500, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "type": "stat",
        "title": "Active Miners",
        "targets": [{
          "expr": "count(max by (ip) (miner_scrape_status) >= 1)",
          "legendFormat": "Active"
        }],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "unit": "short",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 15, "color": "yellow"},
                {"value": 20, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "type": "stat",
        "title": "Total Power",
        "targets": [{
          "expr": "sum(max by (ip) (miner_power_watts)) / 1000",
          "legendFormat": "Power"
        }],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "unit": "kW",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 60, "color": "yellow"},
                {"value": 70, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "type": "stat",
        "title": "Avg Efficiency",
        "targets": [{
          "expr": "avg(max by (ip) (miner_efficiency_j_th))",
          "legendFormat": "Efficiency"
        }],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "unit": "J/TH",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 30, "color": "yellow"},
                {"value": 35, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 4},
        "type": "stat",
        "title": "Total Hashrate (SCRYPT)",
        "targets": [{
          "expr": "sum(max by (ip) (miner_hashrate_mhs{algorithm=\"scrypt\"}))",
          "legendFormat": "SCRYPT"
        }],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "unit": "MH/s",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 10000, "color": "yellow"},
                {"value": 50000, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "type": "timeseries",
        "title": "Farm Hashrate Over Time (SHA-256)",
        "targets": [{
          "expr": "sum(max by (ip) (miner_hashrate_ths{algorithm=\"sha256\"}))",
          "legendFormat": "SHA-256 Hashrate"
        }],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "fillOpacity": 20,
              "showPoints": "never",
              "spanNulls": true,
              "axisPlacement": "auto",
              "axisLabel": "Hashrate (TH/s)",
              "scaleDistribution": {
                "type": "linear"
              }
            },
            "unit": "TH/s",
            "color": {
              "mode": "palette-classic"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"}
              ]
            }
          }
        },
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "none"
          },
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "calcs": ["lastNotNull", "mean", "max"]
          }
        }
      },
      {
        "id": 6,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "type": "timeseries",
        "title": "Power Consumption Over Time",
        "targets": [{
          "expr": "sum(max by (ip) (miner_power_watts)) / 1000",
          "legendFormat": "Total Power"
        }],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "fillOpacity": 20,
              "showPoints": "never",
              "spanNulls": true,
              "axisPlacement": "auto",
              "axisLabel": "Power (kW)",
              "scaleDistribution": {
                "type": "linear"
              }
            },
            "unit": "kW",
            "color": {
              "mode": "palette-classic"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 60, "color": "yellow"},
                {"value": 70, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "none"
          },
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "calcs": ["lastNotNull", "mean", "max"]
          }
        }
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
        "type": "timeseries",
        "title": "Farm Rejection Rate - Lifetime",
        "targets": [{
          "expr": "100 * (sum(max by (ip) (miner_pool_rejected_total)) / (sum(max by (ip) (miner_pool_accepted_total)) + sum(max by (ip) (miner_pool_rejected_total))))",
          "legendFormat": "Rejection Rate"
        }],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "fillOpacity": 20,
              "showPoints": "never",
              "spanNulls": true,
              "axisPlacement": "auto",
              "axisLabel": "Rejection Rate (%)",
              "scaleDistribution": {
                "type": "linear"
              }
            },
            "unit": "percent",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 2, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "none"
          },
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "calcs": ["lastNotNull", "mean", "max"]
          }
        }
      },
      {
        "id": 8,
        "gridPos": {"h": 12, "w": 24, "x": 0, "y": 20},
        "type": "table",
        "title": "Miner Status",
        "targets": [
          {
            "expr": "max by (ip, name, model, algorithm) (miner_hashrate_ths{algorithm=\"sha256\"})",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "max by (ip, name, model, algorithm) (miner_hashrate_mhs{algorithm=\"scrypt\"})",
            "format": "table",
            "instant": true,
            "refId": "E"
          },
          {
            "expr": "max by (ip, algorithm) (miner_power_watts)",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "max by (ip, algorithm) (miner_temp_max_c)",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "100 * (miner_pool_rejected_total / (miner_pool_accepted_total + miner_pool_rejected_total))",
            "format": "table",
            "instant": true,
            "refId": "D"
          }
        ],
        "transformations": [
          {
            "id": "merge",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true},
              "indexByName": {
                "name": 0,
                "ip": 1,
                "model": 2,
                "Value #A": 3,
                "Value #B": 4,
                "Value #C": 5,
                "Value #D": 6
              },
              "renameByName": {
                "name": "Miner",
                "ip": "IP",
                "model": "Model",
                "Value #A": "Hashrate (TH/s)",
                "Value #B": "Power (W)",
                "Value #C": "Temp (°C)",
                "Value #D": "Rejection (%)"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Temp (°C)"},
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": {"type": "color-background"}
                },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {"value": 0, "color": "green"},
                      {"value": 75, "color": "yellow"},
                      {"value": 85, "color": "orange"},
                      {"value": 95, "color": "red"}
                    ]
                  }
                }
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Rejection (%)"},
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": {"type": "color-background"}
                },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {"value": 0, "color": "green"},
                      {"value": 2, "color": "yellow"},
                      {"value": 5, "color": "red"}
                    ]
                  }
                },
                {
                  "id": "decimals",
                  "value": 2
                }
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Hashrate (TH/s)"},
              "properties": [
                {"id": "decimals", "value": 1}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Power (W)"},
              "properties": [
                {"id": "decimals", "value": 0}
              ]
            }
          ]
        }
      }
    ]
}
