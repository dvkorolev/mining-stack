{
  "id": null,
  "uid": "scrypt-miners",
  "title": "SCRYPT Miners Dashboard",
  "tags": ["mining", "scrypt", "litecoin", "dogecoin"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Back to Overview",
      "url": "/d/mining-farm-overview",
      "type": "link"
    }
  ],
  "liveNow": false,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "type": "stat",
      "title": "Total SCRYPT Hashrate (GH/s)",
      "targets": [{
        "expr": "sum(max by (ip) (miner_hashrate_mhs{algorithm=\"scrypt\"}))/1000",
        "legendFormat": "Total GH/s",
        "refId": "A"
      }],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "value_and_name",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 10, "color": "yellow"},
              {"value": 20, "color": "green"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "type": "stat",
      "title": "Active SCRYPT Miners",
      "targets": [{
        "expr": "count(miner_state{algorithm=\"scrypt\"} == 2)",
        "legendFormat": "Online",
        "refId": "A"
      }],
      "options": {
        "graphMode": "none",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "value_and_name",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "type": "stat",
      "title": "Average Power (SCRYPT)",
      "targets": [{
        "expr": "avg(miner_power_watts{algorithm=\"scrypt\"})",
        "legendFormat": "Avg Power",
        "refId": "A"
      }],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "value_and_name",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 3000, "color": "yellow"},
              {"value": 4000, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "type": "stat",
      "title": "Efficiency (MH/W)",
      "targets": [{
        "expr": "sum(miner_hashrate_mhs{algorithm=\"scrypt\"}) / sum(miner_power_watts{algorithm=\"scrypt\"})",
        "legendFormat": "MH/W",
        "refId": "A"
      }],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "orientation": "auto",
        "textMode": "value_and_name",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 5, "color": "yellow"},
              {"value": 7, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "type": "timeseries",
      "title": "SCRYPT Hashrate Over Time (GH/s)",
      "targets": [{
        "expr": "miner_hashrate_mhs{algorithm=\"scrypt\"}/1000",
        "legendFormat": "{{name}} ({{ip}})",
        "refId": "A"
      }],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "mean", "max", "min"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 15, "color": "yellow"},
              {"value": 20, "color": "green"}
            ]
          }
        }
      }
    },
